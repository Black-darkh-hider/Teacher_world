# MongoDB Connection
MONGODB_URI=mongodb://localhost:27017/job-portal

# JWT Configuration
JWT_SECRET=your_strong_random_jwt_secret_here
JWT_REFRESH_SECRET=your_strong_random_refresh_secret_here
JWT_REFRESH_EXPIRY=7d

# Gmail Configuration (for OTP emails)
GMAIL_USER=your_email@gmail.com
GMAIL_PASSWORD=your_16_digit_gmail_app_password

# Gemini API Keys
GEMINI_API_KEY=your_backend_gemini_api_key
VITE_GEMINI_API_KEY=your_frontend_gemini_api_key

# Google Maps API Key
VITE_GOOGLE_MAPS_API_KEY=your_google_maps_api_key

# Server Configuration
PORT=5000
NODE_ENV=development

# Frontend URL (for CORS)
FRONTEND_URL=http://localhost:5173

# OTP Settings (10 minutes)
OTP_EXPIRY=600000

# Zoom Configuration
ZOOM_CLIENT_ID=your_zoom_client_id
ZOOM_CLIENT_SECRET=your_zoom_client_secret
ZOOM_REDIRECT_URL=http://localhost:5000/zoom/callback
ZOOM_ACCOUNT_ID=your_zoom_account_id_here
